# WorCoor Frontend Environment Variables
# Copy this file to .env.local for local development
# For Vercel deployment, set these in the Vercel dashboard

# ===========================================
# API Configuration
# ===========================================
# HTTP API URL - Leave empty to use Next.js rewrites (recommended for Vercel)
# In production, this should be empty or point to your backend domain
NEXT_PUBLIC_API_URL=

# Socket.IO URL - MUST point directly to backend (cannot use Next.js rewrites)
# Local: http://localhost:4000
# Production: https://your-backend-domain.onrender.com
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Backend URL for Next.js rewrites (server-side only, not exposed to browser)
# Local: http://localhost:4000
# Production: https://your-backend-domain.onrender.com
BACKEND_URL=http://localhost:4000